  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#646464",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string"],
      "settings": {
        "foreground": "#a8a8a8"
      }
    },
    {
      "scope": ["punctuation.definition.string"],
      "settings": {
        "foreground": "#7a7a7a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#c2c2c2"
      }
    },
    {
      "scope": ["variable"],
      "settings": {
        "foreground": "#e0e0e0"
      }
    },
    {
      "scope": ["variable.parameter", "meta.parameters variable"],
      "settings": {
        "foreground": "#b8b8b8"
      }
